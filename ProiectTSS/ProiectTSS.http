@ProiectTSS_HostAddress = http://localhost:5158

### 1) BRACKETS - Local, weight 0-1kg
POST {{ProiectTSS_HostAddress}}/shipping/quote
Content-Type: application/json

{
  "zone": "Local",
  "subtotal": 100,
  "options": { "rapid": false, "fragil": false },
  "parcels": [
    { "weightKg": 0.8, "size": "Small" }
  ],
  "pricingModel": "Brackets",
  "roundingRule": "None"
}

### 2) BRACKETS - National, weight 1-5kg
POST {{ProiectTSS_HostAddress}}/shipping/quote
Content-Type: application/json

{
  "zone": "National",
  "subtotal": 120,
  "options": { "rapid": false, "fragil": false },
  "parcels": [
    { "weightKg": 3.2, "size": "Medium" }
  ],
